<Application x:Class="FocusGuard.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#F4F6F8"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InkBrush" Color="#17202A"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#657383"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1D7A8C"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#135967"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#17202A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E2E7EC"/>
        <SolidColorBrush x:Key="InputBrush" Color="#FFFFFF"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
        </Style>
    </Application.Resources>
</Application>
