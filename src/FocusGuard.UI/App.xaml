<Application x:Class="FocusGuard.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#111315"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#191D20"/>
        <SolidColorBrush x:Key="InkBrush" Color="#F1F3F1"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9CA6A1"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#36A269"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#7BD89C"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#38413D"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#A84545"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2B3230"/>
        <SolidColorBrush x:Key="InputBrush" Color="#101315"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
        </Style>
    </Application.Resources>
</Application>
