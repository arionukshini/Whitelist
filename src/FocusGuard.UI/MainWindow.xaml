<Window x:Class="FocusGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FocusGuard.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FocusGuard" Height="760" Width="1180" MinHeight="660" MinWidth="1000"
        Background="{DynamicResource BgBrush}">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="22"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" Padding="22">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FocusGuard" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Local allowlist focus mode" Foreground="#B8C2CC" Margin="0,6,0,26"/>
                    <ItemsControl ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        Foreground="#E8EEF3"
                                        Margin="0,0,0,6"
                                        Padding="10,9"
                                        Content="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Session" Foreground="#B8C2CC"/>
                    <TextBlock Text="{Binding RemainingText}" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34">
                <TextBlock Text="{Binding SelectedSection}" FontSize="30" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SessionStatusText}" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,24"/>

                <StackPanel Visibility="{Binding IsDashboardSelected, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,18,18">
                            <StackPanel>
                                <TextBlock Text="Focus Session" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding ActiveSessionName}" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding RemainingText}" FontSize="48" FontWeight="SemiBold" Foreground="{DynamicResource AccentDarkBrush}" Margin="0,8,0,16"/>
                                <TextBlock Text="Profile"/>
                                <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name" Margin="0,5,0,12"/>
                                <TextBlock Text="Duration in minutes"/>
                                <TextBox Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,18"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Start Focus Session" Command="{Binding StartSessionCommand}"/>
                                    <Button Content="End Session" Command="{Binding EndSessionCommand}" Background="#8C2F39"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Session Summary" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Selected apps and websites are allowed. Everything else is restricted while a session is active." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/>
                                <Separator Margin="0,18"/>
                                <TextBlock Text="Allowed applications" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding SelectedApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Muted}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Border Style="{StaticResource Card}" Visibility="{Binding IsApplicationsSelected, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Applications" Style="{StaticResource SectionTitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="+ Add Application" Command="{Binding AddApplicationCommand}"/>
                                <Button Content="Import Running Apps" Command="{Binding AddRunningApplicationsCommand}" Background="#59636E"/>
                            </StackPanel>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding SelectedApplications}" BorderThickness="0" MinHeight="380">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,5">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource Card}" Visibility="{Binding IsWebsitesSelected, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Websites" Style="{StaticResource SectionTitle}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding NewWebsite, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="+ Add Website" Command="{Binding AddWebsiteCommand}" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding SelectedWebsites}" BorderThickness="0" MinHeight="380">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,5">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource Card}" Visibility="{Binding IsProfilesSelected, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Profiles" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Create Profile" Command="{Binding CreateProfileCommand}" Margin="8,0,0,0"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Visibility="{Binding IsHistorySelected, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="History" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource MutedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Visibility="{Binding IsSettingsSelected, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Settings" Style="{StaticResource SectionTitle}"/>
                        <CheckBox Content="Dark mode" IsChecked="{Binding IsDarkMode}" Margin="0,0,0,18" Foreground="{DynamicResource InkBrush}"/>
                        <TextBlock Text="Database location" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DatabaseLocation}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,18"/>
                        <TextBlock Text="Browser extension" FontWeight="SemiBold"/>
                        <TextBlock Text="Load the unpacked extension from src\FocusGuard.BrowserExtension in Chrome, Edge, or Brave." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

